PORT=3000
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=1h

# Log inbound API requests + JSON responses and all CBA (simulator) HTTP calls to the terminal (secrets redacted).
# LOG_API_TRAFFIC=false

# --- Google Sign-In (OAuth 2.0 Web client ID from Google Cloud → APIs & Services → Credentials) ---
# Must match the frontend VITE_GOOGLE_CLIENT_ID (same Web application client).
# GOOGLE_OAUTH_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# Optional: comma-separated if you use multiple OAuth clients (e.g. web + Android).
# GOOGLE_OAUTH_CLIENT_IDS=id1.apps.googleusercontent.com,id2.apps.googleusercontent.com
# Map verified Google emails to existing banking usernames (built-in: alice, mahesh, bob or CBA_USERS_*).
# GOOGLE_ACCOUNT_LINK_JSON={"you@gmail.com":"alice"}
# Local dev only: any Google account → this username (do not use in production).
# GOOGLE_OAUTH_FALLBACK_USERNAME=alice

DEFAULT_GATEWAY_ENABLED=true
GENERAL_API_KEY=internal-general-gateway-key

DEFAULT_ACCOUNT_SERVICE_ENABLED=true

# --- CBA UAPI / Mock Server (Swagger: /docs/) ---
CBA_BASE_URL=http://localhost:4000
# Same value used as authToken (query) on account APIs and AuthenticationKey on LocalFundsTransfer
CBA_AUTH_TOKEN=
CBA_TIMEOUT_MS=30000
CBA_CURRENCY=NGN
# Payee alias → destination NUBAN (10 digits from simulator). Omit to use API defaults (includes mahesh, bob, alice, 000168).
# Replace 000168’s NUBAN with the real account for that customer after customer lookup.
# CBA_PAYEE_ACCOUNT_MAP={"mahesh":"1100314089","bob":"1100313855","alice":"1100755299","000168":"1100314089"}

# Real CBA users (optional). If unset, built-in alice/mahesh/bob from src/data/cbaUsers.js are used.
# customerId + accountNumber MUST match the CBA simulator for that login (GetAccountsByCustomerId).
# Customer-by-phone can still work for other numbers even when your JWT user does not match CBA.
# Option A — file: copy cba-users.example.json → cba-users.json (add cba-users.json to .gitignore)
# CBA_USERS_FILE=cba-users.json
# Option B — inline JSON array
# CBA_USERS_JSON=[{"username":"u1","password":"p","customerId":"075529","accountNumber":"1100755299"}]

# LLM tool routing for POST /api/v1/chat (if both keys unset → regex-only NLU)
# CHAT_LLM_ORDER=openai_first  # default: OpenAI first, then Groq on failure
# CHAT_LLM_ORDER=groq_first    # Groq first, then OpenAI on failure
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# When the user writes casually, rewrite the assistant reply to sound more natural (same facts). Uses OPENAI_MODEL.
# CHAT_CONVERSATIONAL_TONE=true

# --- Redis (optional): conversation store + session context (JWT sub/username scoped) ---
# REDIS_ENABLED=false
# Option A — single URL: redis:// = plain TCP, rediss:// = TLS (must match what the port expects).
# ERR_SSL_WRONG_VERSION_NUMBER → try redis:// instead of rediss:// (or the reverse if the console says TLS required).
# REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT
# Option B — host + password (set REDIS_USERNAME=default on Redis Cloud if required)
# REDIS_HOST=your-instance.ec2.cloud.redislabs.com
# REDIS_PORT=19168
# REDIS_USERNAME=default
# REDIS_PASSWORD=
# REDIS_TLS=false
# REDIS_TLS=true
# REDIS_CONVERSATION_TTL_SEC=0
# REDIS_CONVERSATION_MAX_TURNS=20
# REDIS_MAX_USER_MSG_CHARS=8000
# REDIS_MAX_ASSISTANT_MSG_CHARS=8000

# --- RAG (Redis Stack: RedisJSON + RediSearch vectors on same DB as chat) ---
# RAG_ENABLED=true
# RAG_INDEX_NAME=banking_kb_idx
# RAG_KEY_PREFIX=banking:kb:
# RAG_EMBEDDING_MODEL=text-embedding-3-small
# RAG_EMBEDDING_DIM=512
# RAG_TOP_K=5
# RAG_CHUNK_MAX_CHARS=900
# RAG_CHUNK_OVERLAP=120
# RAG_ANSWER_MODEL=gpt-4o-mini
# RAG_SEED_ON_START=false
